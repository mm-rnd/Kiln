{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "xaver.clang-format",
  "editor.insertSpaces": false,
  "editor.tabSize": 4,
  "[c]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },
  "[cpp]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },
  "clang-format.executable": "/Applications/Xcode.app/Contents/Developer/Toolchains/XcodeDefault.xctoolchain/usr/bin/clang-format",
  "clang-format.style": "file",
  "search.exclude": {
    "modules/": true
  },
  "files.exclude": {
    "modules/": true,
    ".gitmodules": true
  },
  "C_Cpp.files.exclude": {},
  "C_Cpp.default.compilerPath": "/usr/bin/clang"
}
