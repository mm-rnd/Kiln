{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Attach to Reaper",
            "type": "cppdbg",
            "request": "attach",
            "program": "/Applications/REAPER.app/Contents/MacOS/REAPER",
            "processId": "${command:pickProcess}",
            "MIMode": "lldb",
            "setupCommands": [
                {
                    "description": "Enable pretty printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
